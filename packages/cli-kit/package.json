{
  "name": "@makibm/cli-kit",
  "version": "1.0.0",
  "description": "Shared CLI shell for MakiBM tools: logo generation, color palette, help formatter, interactive menus, spinner.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "tui",
    "figlet",
    "makibm"
  ],
  "author": "Bartek Makos",
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "figlet": "^1.7.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0"
  }
}
