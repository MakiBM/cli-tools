{
  "name": "@makibm/gites",
  "version": "1.1.0",
  "description": "Two-track git workflow for batching and timing commits",
  "license": "MIT",
  "author": "Bartek Makos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakiBM/cli-tools.git",
    "directory": "packages/gites"
  },
  "bin": {
    "gites": "./dist/bin/gites.js"
  },
  "files": [
    "dist",
    "hooks"
  ],
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/bin/gites.js",
    "dev": "tsx bin/gites.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "demo": "tsx scripts/demo.ts",
    "demo:reset": "tsx scripts/demo.ts --reset",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "@makibm/cli-kit": "workspace:^",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
