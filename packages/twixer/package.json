{
  "name": "@makibm/twixer",
  "version": "1.0.0",
  "description": "Find Tailwind v4 arbitrary-value classes (e.g. text-[13px], bg-[#abc]) and suggest the matching default token from your @theme.",
  "type": "module",
  "bin": {
    "twixer": "./dist/bin/twixer.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/bin/twixer.js",
    "dev": "tsx bin/twixer.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@makibm/cli-kit": "workspace:^",
    "glob": "^10.3.10",
    "ignore": "^7.0.5"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "tailwind-v4",
    "arbitrary",
    "magic-numbers",
    "lint",
    "audit",
    "cli"
  ],
  "author": "Bartek Makos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakiBM/makibm-tools.git",
    "directory": "packages/twixer"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
